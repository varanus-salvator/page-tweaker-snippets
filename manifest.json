{
  "manifest_version": 3,
  "name": "Page Gremlin",
  "version": "1.2",
  "description": "Inject custom JS/CSS per URL pattern",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    { "resources": ["Readability.js"], "matches": ["<all_urls>"] }
  ],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg"
    }
  },
  "icons": {
    "48": "icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "page-gremlin@lumphini.org",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
